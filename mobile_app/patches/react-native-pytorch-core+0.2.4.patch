 task extractAARForNativeBuild {
+    // Force this task to always run — never trust cache for patched native artifacts
+    outputs.upToDateWhen { false }
+
     doLast {
         configurations.extractForNativeBuild.files.each {
             def file = it.absoluteFile
+            def targetDir = new File("$buildDir/$file.name")
+
+            // Nuke any stale extraction from previous versions
+            if (targetDir.exists()) {
+                delete targetDir
+            }
+
             copy {
                 from zipTree(file)
                 into "$buildDir/$file.name"
                 include "headers/**"
                 include "jni/**"
             }
+            
+            // Post-process the extracted headers to patch NDK 27 STL compatibility
+            def macrosFile = new File("$buildDir/$file.name/headers/c10/macros/Macros.h")
+            if (macrosFile.exists()) {
+                def content = macrosFile.text
+                content = content.replace('__has_trivial_copy(T)', '__is_trivially_copyable(T)')
+                macrosFile.text = content
+            }
+
+            // Fix corrupted ELF dynamic symbol tables for NDK 27 LLD 18
+            // PyTorch prebuilt .so files have STB_LOCAL symbols in the global
+            // partition of .dynsym. llvm-objcopy can't fix .dynsym, so we use
+            // a Python script to directly patch the ELF binary.
+            def fixScript = new File(rootDir, "../fix_elf_dynsym.py")
+            if (fixScript.exists()) {
+                fileTree(dir: "$buildDir/$file.name/jni", include: "**/*.so").each { soFile ->
+                    def args = new ArrayList<String>()
+                    args.add("python")
+                    args.add(fixScript.absolutePath.toString())
+                    args.add(soFile.absolutePath.toString())
+                    def proc = new ProcessBuilder(args).redirectErrorStream(true).start()
+                    def output = proc.inputStream.text
+                    proc.waitFor()
+                    if (output.trim()) println output.trim()
+                }
+            }
         }
     }
 }
